# OpenAI API Configuration
# Required for running the live medical term taxonomy classification command (classify-terms)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override the model specified in configs/llm.yaml (e.g. gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Hugging Face Configuration (Optional)
# Only required if you need to authenticate with Hugging Face Hub
# HF_TOKEN=your_huggingface_token_here
